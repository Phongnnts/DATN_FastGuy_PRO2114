meta {
  name: Create Order
  method: POST
  type: http
  seq: 2
}

post {
  url: http://localhost:8082/FastGuy/api/orders
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{token}}
}

body:json {
  {
    "zoneId": 1,
    "address": "123, Phường Bến Nghé, Quận 1",
    "phone": "0900000001",
    "paymentMethod": "COD",
    "deliveryNote": "Giao giờ hành chính"
  }
}
