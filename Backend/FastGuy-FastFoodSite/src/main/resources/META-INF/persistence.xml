<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

  <persistence-unit name="FastGuyPU" transaction-type="RESOURCE_LOCAL">


    <!-- Entity classes -->
    <class>entity.User</class>
    <class>entity.Role</class>
    <class>entity.Permission</class>
    <class>entity.Address</class>
    <class>entity.DeliveryZone</class>
    <class>entity.Category</class>
    <class>entity.Product</class>
    <class>entity.ProductOption</class>
    <class>entity.Cart</class>
    <class>entity.CartItem</class>
    <class>entity.Orders</class>
    <class>entity.OrderItem</class>
    <class>entity.Payment</class>
    <class>entity.Ingredient</class>
    <class>entity.ProductIngredient</class>
    <class>entity.InventoryTransaction</class>
    <class>entity.WorkShift</class>
    <class>entity.Schedule</class>
    <class>entity.Review</class>

    <properties>
      <property name="jakarta.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>
      <property name="jakarta.persistence.jdbc.url"
                value="jdbc:sqlserver://localhost:1433;databaseName=FastGuy;encrypt=false"/>
      <property name="jakarta.persistence.jdbc.user" value="JavaDuAn"/>
      <property name="jakarta.persistence.jdbc.password" value="ZaZksnguyen1234"/>

      <property name="hibernate.dialect" value="org.hibernate.dialect.SQLServerDialect"/>
      <property name="hibernate.hbm2ddl.auto" value="validate"/>
      <property name="hibernate.show_sql" value="false"/>
      <property name="hibernate.format_sql" value="true"/>
      <property name="hibernate.enable_lazy_load_no_trans" value="true"/>
    </properties>
  </persistence-unit>
</persistence>
