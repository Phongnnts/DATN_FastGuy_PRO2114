<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="FastGuyPU" transaction-type="RESOURCE_LOCAL">
        <class>entity.Role</class>
        <class>entity.User</class>
        <class>entity.PasswordResetToken</class>
        <class>entity.Address</class>
        <class>entity.DeliveryZone</class>
        <class>entity.Category</class>
        <class>entity.Product</class>
        <class>entity.ProductVariant</class>
        <class>entity.ProductModifierGroup</class>
        <class>entity.ProductModifierOption</class>
        <class>entity.ProductCombo</class>
        <class>entity.ProductComboItem</class>
        <class>entity.Cart</class>
        <class>entity.CartItem</class>
        <class>entity.Orders</class>
        <class>entity.OrderItem</class>
        <class>entity.OrderItemModifier</class>
        <class>entity.Coupon</class>
        <class>entity.CouponUsage</class>
        <class>entity.ClaimedCoupon</class>
        <class>entity.Banner</class>
        <class>entity.Review</class>
        <class>entity.FavoriteProduct</class>
        <class>entity.Notification</class>
        <class>entity.SupportTicket</class>
        <class>entity.OrderStatusHistory</class>
        <class>entity.LoyaltyTransaction</class>
        <class>entity.WorkShift</class>
        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.SQLServerDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="none"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>
</persistence>
